<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="MyAdminExplorer.AddUser"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="MyAdminExplorer — Add User" Height="650" Width="500">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Label FontSize="16" Grid.Row="0" Grid.Column="0" Content="Login" Margin="0,0,12,8"/>
        <TextBox FontSize="16" Grid.Row="0" Grid.Column="1" x:Name="login" Margin="0,0,0,8"/>
        <Label FontSize="16" Grid.Row="1" Grid.Column="0" Content="Password" Margin="0,0,12,8"/>
        <PasswordBox FontSize="16" Grid.Row="1" Grid.Column="1" x:Name="password" Margin="0,0,0,8"/>
        <Label FontSize="16" Grid.Row="2" Grid.Column="0" Content="Role" Margin="0,0,12,8"/>
        <Label FontSize="16" Grid.Row="2" Grid.Column="1" Content="User (0)" Margin="0,0,0,8"/>
        <Calendar Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" x:Name="from" Margin="0,0,0,8"/>
        <Calendar Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="to" Margin="0,0,0,8"/>
        <Label Content="From (hour)" Grid.Row="5" Grid.Column="0" FontSize="16" Margin="0,0,12,8"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="0" FontSize="16" x:Name="fromtime" Margin="0,0,0,8"/>
        <Label Content="To (hour)" Grid.Row="6" Grid.Column="0" FontSize="16" Margin="0,0,12,8"/>
        <TextBox Grid.Row="6" Grid.Column="1" Text="24" FontSize="16" x:Name="totime" Margin="0,0,0,8"/>
        <CheckBox Grid.Row="7" Grid.ColumnSpan="2" FontSize="16" x:Name="even" Content="Even days only" Margin="0,0,0,12"/>
        <StackPanel Grid.Row="8" Grid.ColumnSpan="2">
            <Button Content="Edit blocked folders" Click="EditBlockedFolders" Margin="0,0,0,8"/>
            <Button Content="Add" Click="Add" Margin="0,0,0,8"/>
            <Button Content="Close" Click="CloseWindow"/>
        </StackPanel>
    </Grid>
</Window>
